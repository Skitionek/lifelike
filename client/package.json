{
  "name": "client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev-start": "ng serve --host=0.0.0.0 --disable-host-check --proxy-config=proxy.conf.js --source-map=true",
    "build": "node --max_old_space_size=4096 ./node_modules/@angular/cli/bin/ng build --prod",
    "test": "ng test --watch=false --progress=false --browsers=ChromeCustom",
    "test:codespace": "npx -y @puppeteer/browsers install chrome@stable --path ~/.cache/puppeteer >/dev/null && NODE_OPTIONS=--openssl-legacy-provider ng test --watch=false --progress=false --browsers=ChromeCustom",
    "test:codespace:watch": "npx -y @puppeteer/browsers install chrome@stable --path ~/.cache/puppeteer >/dev/null && NODE_OPTIONS=--openssl-legacy-provider ng test --watch=true --progress=false --browsers=ChromeCustom",
    "lint": "tslint --formatters-dir ./tslint --project . --format groupedStylish",
    "lint-ci": "yarn lint --format groupedProse",
    "e2e": "ng e2e",
    "compileTsLintCustomisations": "tsc tslint/*.ts"
  },
  "lint-staged": {
    "*.ts": "yarn lint"
  },
  "private": true,
  "dependencies": {
