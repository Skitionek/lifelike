{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Appserver Flask (uv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/appserver/.venv/bin/python",
      "module": "flask",
      "cwd": "${workspaceFolder}/appserver",
      "args": [
        "run",
        "--host",
        "0.0.0.0",
        "--port",
        "5000",
        "--no-debugger",
        "--no-reload"
      ],
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_ENV": "development",
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5432",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "postgres",
        "POSTGRES_DB": "postgres",
        "NEO4J_HOST": "localhost",
        "NEO4J_PORT": "7687",
        "NEO4J_AUTH": "neo4j/password",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_SCHEME": "bolt"
      },
      "jinja": true,
      "justMyCode": false,
      "preLaunchTask": "uv sync: appserver"
    },
    {
      "name": "Python: Appserver Pytest unit (uv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/appserver/.venv/bin/python",
      "module": "pytest",
      "cwd": "${workspaceFolder}/appserver",
      "args": [
        "tests/unit/",
        "-v"
      ],
      "env": {
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5432",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "postgres",
        "POSTGRES_DB": "postgres"
      },
      "justMyCode": false,
      "preLaunchTask": "uv sync: appserver"
    },
    {
      "name": "Python: Cache Invalidator Main (uv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/cache-invalidator/.venv/bin/python",
      "program": "${workspaceFolder}/cache-invalidator/main.py",
      "cwd": "${workspaceFolder}/cache-invalidator",
      "env": {
        "LOG_LEVEL": "INFO",
        "NEO4J_HOST": "localhost",
        "NEO4J_PORT": "7687",
        "NEO4J_AUTH": "neo4j/password",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_SCHEME": "bolt",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_PASSWORD": "",
        "REDIS_DB": "0",
        "CACHE_TTL": "3600"
      },
      "justMyCode": false,
      "preLaunchTask": "uv sync: cache-invalidator"
    },
    {
      "name": "Python: Cache Invalidator Pytest (uv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/cache-invalidator/.venv/bin/python",
      "module": "pytest",
      "cwd": "${workspaceFolder}/cache-invalidator",
      "args": [
        "tests/",
        "-v"
      ],
      "justMyCode": false,
      "preLaunchTask": "uv sync: cache-invalidator"
    },
    {
      "name": "Python: Statistical Enrichment Flask (uv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/statistical-enrichment/.venv/bin/python",
      "module": "flask",
      "cwd": "${workspaceFolder}/statistical-enrichment",
      "args": [
        "run",
        "--host",
        "0.0.0.0",
        "--port",
        "5000",
        "--no-debugger",
        "--no-reload"
      ],
      "env": {
        "FLASK_APP": "wsgi.py",
        "FLASK_ENV": "development",
        "NEO4J_HOST": "localhost",
        "NEO4J_PORT": "7687",
        "NEO4J_AUTH": "neo4j/password",
        "NEO4J_SCHEME": "bolt",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_PASSWORD": "",
        "REDIS_DB": "0",
        "CACHE_TTL": "3600"
      },
      "jinja": true,
      "justMyCode": false,
      "preLaunchTask": "uv sync: statistical-enrichment"
    },
    {
      "name": "Python: Statistical Enrichment Pytest (uv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/statistical-enrichment/.venv/bin/python",
      "module": "pytest",
      "cwd": "${workspaceFolder}/statistical-enrichment",
      "args": [
        "tests/",
        "-v"
      ],
      "justMyCode": false,
      "preLaunchTask": "uv sync: statistical-enrichment"
    },
    {
      "name": "TypeScript: Client in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/client",
      "sourceMaps": true,
      "preLaunchTask": "client: install-and-dev-start"
    },
    {
      "name": "TypeScript: Attach to Chrome (9222)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/client"
    },
    {
      "name": "TypeScript: Client Karma Tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd ${workspaceFolder}/client && if command -v yarn >/dev/null 2>&1; then if [ \"${CODESPACES:-}\" = \"true\" ]; then yarn test:codespace:watch; else yarn test --watch=true --progress=false --browsers=ChromeCustom; fi; elif command -v corepack >/dev/null 2>&1; then if [ \"${CODESPACES:-}\" = \"true\" ]; then corepack yarn test:codespace:watch; else corepack yarn test --watch=true --progress=false --browsers=ChromeCustom; fi; else if [ \"${CODESPACES:-}\" = \"true\" ]; then npm run test:codespace:watch; else npm run test -- --watch=true --progress=false --browsers=ChromeCustom; fi; fi"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Appserver + Client",
      "configurations": [
        "Python: Appserver Flask (uv)",
        "TypeScript: Client in Chrome"
      ]
    },
    {
      "name": "Python: Debug all backend tests",
      "configurations": [
        "Python: Appserver Pytest unit (uv)",
        "Python: Cache Invalidator Pytest (uv)",
        "Python: Statistical Enrichment Pytest (uv)"
      ]
    }
  ]
}
