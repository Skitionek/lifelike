                                "cvssv3_baseScore": 9.1,
                                "cvssv3_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N",
                                "precision": "very-high",
                                "security-severity": "9.1",
                                "tags": [
                                    "vulnerability",
                                    "security",
                                    "CRITICAL"
