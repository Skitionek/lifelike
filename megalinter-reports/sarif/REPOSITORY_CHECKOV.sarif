                },
                "region": {
                  "endLine": 11,
                  "snippet": {
                    "text": "ARG ELASTICSEARCH_VERSION=7.16.3\nFROM docker.elastic.co/elasticsearch/elasticsearch:${ELASTICSEARCH_VERSION}\n\nLABEL org.opencontainers.image.source https://github.com/SBRG/lifelike\nLABEL org.opencontainers.image.description Custom Elasticsearch image for Lifelike\n\n# Install ingest-attachment plugin\nRUN elasticsearch-plugin install --batch ingest-attachment\n\n# Set default configuration environment variables\nENV http.max_content_length=200mb"
                  },
                  "startLine": 1
                }
              }
            }
