              "physicalLocation": {
                "artifactLocation": {
                  "uri": "graph-db/migrator/Dockerfile"
                },
                "region": {
                  "endLine": 56,
                  "snippet": {
                    "text": "ADD --chown=liquibase:liquibase https://raw.githubusercontent.com/vishnubob/wait-for-it/81b1373f17855a4dc21156cfe1694c31d7d1792e/wait-for-it.sh /wait-for-it.sh\n"
                  },
